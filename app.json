{
  "expo": {
    "name": "Baby Names Finder",
    "slug": "baby-name-finder",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F0E8"
    },
    "platforms": [
      "web",
      "ios"
    ],
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "scheme": "babynamefinder",
    "ios": {
      "bundleIdentifier": "com.lukeholder.babynamefinder",
      "buildNumber": "3",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    }
  }
}
